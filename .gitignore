cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.sqlite3
.env
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# Django
staticfiles/
media/

# Node
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
EOF