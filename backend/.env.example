POSTGRES_DB=workspacecanvas
POSTGRES_USER=workspacecanvas
POSTGRES_PASSWORD=workspacecanvas
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Required in ALL environments — the server will not start without this.
# Generate one with: python -c "import secrets; print(secrets.token_hex(50))"
# Never share or commit this value.
DJANGO_SECRET_KEY=REPLACE-THIS-WITH-A-REAL-SECRET-KEY

# Required. Set True for local development, False in all other environments.
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@workspacecanvas.local
# Use a strong password here. This example value must not be used in any real environment.
DJANGO_SUPERUSER_PASSWORD=Change-Me-Before-Running!

# Email backend.
# console: prints emails to stdout — useful locally to see verification links.
# dummy:   silently discards emails — use in CI or when email output is unwanted.
# smtp:    real delivery — fill in the SMTP block below and change EMAIL_BACKEND.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=WorkspaceCanvas <noreply@workspacecanvas.local>
FRONTEND_URL=http://localhost:5173

# SMTP settings — only used when EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#
# Gmail example:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to Google Account → Security → App passwords → create one for "Mail".
#   3. Paste the 16-character app password into EMAIL_HOST_PASSWORD below.
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=you@gmail.com
#   EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
#   DEFAULT_FROM_EMAIL=WorkspaceCanvas <you@gmail.com>
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# CORS — comma-separated list of allowed origins.
# In production set this to your actual frontend domain, e.g.:
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.workspacecanvas.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

MFA_ISSUER_NAME=WorkspaceCanvas
MFA_TOTP_INTERVAL=30
MFA_TOTP_DIGITS=6
MFA_RECOVERY_CODE_COUNT=10
MFA_CHALLENGE_LIFETIME_MINUTES=5

# Auth endpoint throttle rates (default values shown).
# Increase for load testing; decrease to tighten security.
# Format: <count>/<period>  e.g. 5/min, 100/hour, 1000/day
THROTTLE_AUTH_LOGIN=5/min
THROTTLE_AUTH_SIGNUP=5/min
THROTTLE_AUTH_RESEND=3/min
THROTTLE_AUTH_MFA_CHALLENGE=5/min
THROTTLE_AUTH_SOCIAL=10/min
THROTTLE_AUTH_PROFILE=30/min

# Workspace endpoint throttle rates (default values shown).
THROTTLE_ORG_CREATE=5/hour
THROTTLE_INVITE_WRITE=60/hour     # invitation create / cancel / accept (per user)
THROTTLE_INVITE_READ=120/hour     # public invitation-detail lookup (per IP)
THROTTLE_OFFICE_CREATE=30/hour
THROTTLE_FLOOR_CREATE=60/hour
THROTTLE_LAYOUT_OBJECT_WRITE=120/hour
THROTTLE_DESK_WRITE=120/hour
THROTTLE_DESK_BOOKING_WRITE=60/hour
THROTTLE_DESK_BOOKING_READ=120/hour
